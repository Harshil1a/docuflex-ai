# DocuFlex AI - Environment Configuration Template
# Copy this file to ".env" and fill in your actual keys.
# NEVER commit the actual ".env" file to Git.

# --- Backend Configuration ---
SERVER_PORT=8081
ADMIN_REGISTRATION_KEY=admin_password_here
JWT_SECRET=generate_a_long_random_string_here

# --- MongoDB Atlas ---
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/docuflex

# --- AI Integration ---
GROQ_API_KEY=your_groq_api_key_here

# --- Google OAuth (Optional) ---
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# --- Cloud Storage (AWS S3) ---
STORAGE_MODE=s3 # Options: 'local' or 's3'
AWS_S3_BUCKET=your_bucket_name
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# --- Local Storage (If mode is 'local') ---
DOCUFLEX_STORAGE=uploads
